# OpenAI
OPENAI_API_KEY=sk-your-key

# SEC EDGAR contact email (required for API compliance)
SEC_CONTACT_EMAIL=your-email@example.com

# Optional live news integration
NEWS_API_KEY=your-newsapi-key

# Local storage paths
FAISS_INDEXES_DIR=data/faiss_indexes
SQLITE_DB_PATH=data/chat_memory.db
UPLOAD_DIR=data/uploads
SEC_FILINGS_DIR=data/sec_filings

# Model choices
CHAT_MODEL=gpt-4o
PLANNER_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Practical limits
RETRIEVAL_K=12
MAX_UPLOAD_MB=25
MAX_TOOL_CALLS=6
MAX_CONTEXT_TOKENS=7000
# Set true only if you need to read old local FAISS indexes without manifests.
TRUST_LEGACY_FAISS_INDEXES=false

# API
API_HOST=0.0.0.0
API_PORT=8000
# Leave blank for local demos; set a value to require x-api-key.
API_SECRET_KEY=
